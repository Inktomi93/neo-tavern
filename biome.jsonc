{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "root": true,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    // routeTree.gen.ts is generated by the TanStack Router plugin. We commit it
    // (so `pnpm check` works from a clean clone with no codegen step) but never
    // lint or format it ourselves. .claude/ is harness-managed, not our source.
    "includes": ["**", "!**/routeTree.gen.ts", "!.claude", "!references"]
  },
  "formatter": {
    "enabled": true,
    // .editorconfig is the editor-agnostic base; anything set here overrides it.
    "useEditorconfig": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf",
    "bracketSpacing": true,
    "attributePosition": "auto",
    "expand": "auto"
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        // Single source of truth for import order. Object-key order is semantic
        // in our configs, so we do NOT auto-sort keys.
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    // Domains activate Biome's project/type analysis. WITHOUT "project", the
    // type-aware rules below (noFloatingPromises, noMisusedPromises,
    // useAwaitThenable, noBaseToString, noImportCycles) silently degrade to
    // syntactic-only checks and appear green while doing nothing. "react" and
    // "test" pull in their framework rule sets.
    "domains": {
      "project": "recommended",
      "react": "recommended",
      "test": "recommended"
    },
    "rules": {
      "recommended": true,
      "correctness": {
        // Dead code — caught by both tsc and Biome; Biome gives the autofix.
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedPrivateClassMembers": "error",
        // Phantom-dependency guard: every import must be in package.json.
        "noUndeclaredDependencies": "error",
        // Force `import process from "node:process"` over the ambient global.
        "noProcessGlobal": "error",
        // React correctness.
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error",
        "useJsxKeyInIterable": "error"
      },
      "style": {
        // Type-only imports/exports, paired with tsconfig verbatimModuleSyntax.
        "useImportType": "error",
        "useExportType": "error",
        "useNodejsImportProtocol": "error",
        // No escape hatches / no implicit module-shape surprises.
        "noNonNullAssertion": "error",
        "noDefaultExport": "error",
        "noNamespace": "error",
        // Funnel all logging through the observability module — no hand-rolled
        // loggers. (Scoped OFF for src/server/observability/** where pino lives.)
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "pino": "Don't create a logger. Import getLog() from src/server/observability/logger.",
              "pino-pretty": "pino-pretty is a dev CLI transport (piped in dev:server), not an import."
            }
          }
        },
        // Erasable-TS discipline: union literals over enums, no constructor
        // parameter properties. Keeps runtime semantics out of type syntax.
        "noEnum": "error",
        "noParameterProperties": "error",
        "noParameterAssign": "error",
        "noNestedTernary": "error",
        "useThrowNewError": "error",
        "useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } },
        // strictCase:false so acronyms like "RPCClient" are allowed.
        "useNamingConvention": { "level": "error", "options": { "strictCase": false } },
        "useFilenamingConvention": {
          "level": "error",
          "options": { "requireAscii": true, "filenameCases": ["kebab-case", "PascalCase"] }
        }
      },
      "suspicious": {
        // Raw console is banned in src/server (use the observability logger —
        // see the src/server override below). client + scripts may use these.
        "noConsole": { "level": "error", "options": { "allow": ["info", "warn", "error"] } },
        // Force @ts-expect-error (which fails when the error is gone) over @ts-ignore.
        "noTsIgnore": "error",
        "noEvolvingTypes": "error",
        // Circular imports are an architecture smell that is brutal to unwind late.
        "noImportCycles": "error",
        "noFocusedTests": "error",
        "noSkippedTests": "error"
      },
      "performance": {
        // Barrel files defeat tree-shaking and breed import cycles.
        "noBarrelFile": "error",
        "noReExportAll": "error"
      },
      "nursery": {
        // DB safety: a delete/update without a WHERE clause is a table wipe.
        "noDrizzleDeleteWithoutWhere": "error",
        "noDrizzleUpdateWithoutWhere": "error",
        // Async correctness (type-aware; see linter.domains above).
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "useAwaitThenable": "error",
        "noBaseToString": "error",
        // Exhaustive switch over discriminated unions (mode, role, ...).
        "useExhaustiveSwitchCases": "error",
        "noShadow": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      // Per-language formatter blocks do NOT inherit indent/width from the
      // top-level formatter — they reset to Biome defaults (tab/80). Set them
      // explicitly everywhere so there is one answer, not an inheritance guess.
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100,
      "lineEnding": "lf",
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "attributePosition": "auto"
    },
    "parser": {
      // JSX only in .tsx; a stray tag in a .ts file is a parse error, not silently allowed.
      "jsxEverywhere": false
    },
    // React 19 automatic runtime — no `import React` needed for JSX.
    "jsxRuntime": "transparent"
  },
  "json": {
    "parser": {
      // Our biome.json / tsconfig.json carry comments.
      "allowComments": true,
      "allowTrailingCommas": false
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100,
      "lineEnding": "lf",
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      // Parse Tailwind v4 at-rules (@theme/@apply/@variant) instead of erroring.
      "tailwindDirectives": true
    },
    "formatter": {
      // CSS formatting is off by default in Biome; we want it on.
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100,
      "lineEnding": "lf",
      "quoteStyle": "double"
    }
  },
  "overrides": [
    {
      // Config files legitimately default-export, and read process.env with
      // bracket access (tsc's noPropertyAccessFromIndexSignature requires it),
      // which would otherwise trip useLiteralKeys.
      "includes": ["*.config.ts", "*.config.js", "vite.config.ts", "vitest.config.ts"],
      "linter": {
        "rules": {
          "style": { "noDefaultExport": "off" },
          "complexity": { "useLiteralKeys": "off" }
        }
      }
    },
    {
      // TanStack Router dictates file names (__root.tsx, $param.tsx) and the
      // `export const Route` symbol. Defer naming + export rules to it here.
      "includes": ["src/client/routes/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off",
            "useNamingConvention": "off",
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      // Browser code must never import a Node builtin.
      "includes": ["src/client/**"],
      "linter": { "rules": { "correctness": { "noNodejsModules": "error" } } }
    },
    {
      // env.ts keys mirror real OS environment variable names (CONSTANT_CASE),
      // so they cannot be camelCase here.
      "includes": ["src/server/env.ts"],
      "linter": { "rules": { "style": { "useNamingConvention": "off" } } }
    },
    {
      // The embedder passes transformers.js / onnxruntime option keys verbatim
      // (e.g. session_options, graphOptimizationLevel) — an external API shape, so
      // useNamingConvention can't apply here (cf. the env.ts + importer overrides).
      "includes": ["src/server/embeddings/**"],
      "linter": { "rules": { "style": { "useNamingConvention": "off" } } }
    },
    {
      // Providers are the boundary that speaks external model-API wire formats, whose
      // fields are snake_case by spec — the Agent SDK (stop_reason, total_cost_usd,
      // session_id, cache_creation…) now, OpenRouter/OpenAI (max_tokens, finish_reason)
      // in raw mode. Constructing/asserting those shapes (esp. in tests) must keep the
      // wire names verbatim, so useNamingConvention can't apply here (cf. the importer +
      // embeddings overrides). Same rationale as env.ts's CONSTANT_CASE override. The
      // session-store test builds SDK SessionStoreEntry frames (compact_metadata,
      // preserved_messages…), the same wire shape, so it shares this exemption. So do the seed
      // helpers/probe (domain/chat/seed*, scripts/seed-probe), which synthesize SDK frames with
      // snake_case wire fields (stop_reason) to seed a resumable session.
      "includes": [
        "src/server/providers/**",
        "tests/integration/chat-session-store.test.ts",
        "src/server/domain/chat/seed.ts",
        "src/server/domain/chat/seed.test.ts",
        "scripts/seed-probe.ts",
        "scripts/env-knob-probe.ts",
        "scripts/claude-or-probe.ts"
      ],
      "linter": { "rules": { "style": { "useNamingConvention": "off" } } }
    },
    {
      // The corpus importer parses SillyTavern's external, multi-spec wire JSON,
      // whose field names are snake_case by spec (first_mes, char_name, insertion_order…).
      // Keeping those names visible makes the port auditable against the ST spec +
      // card-curator, so useNamingConvention is off here; useLiteralKeys is off for the
      // bracket access tsc's noPropertyAccessFromIndexSignature requires on raw entries.
      "includes": [
        "src/server/domain/import/**",
        "tests/integration/*-parser.test.ts",
        "tests/integration/import-service.test.ts"
      ],
      "linter": {
        "rules": {
          "style": { "useNamingConvention": "off" },
          "complexity": { "useLiteralKeys": "off" }
        }
      }
    },
    {
      // The ONLY sanctioned barrels: a feature's public API (server domain
      // features + client features). The dependency-cruiser front-door rules
      // force callers to enter a feature via its index, so these index files
      // legitimately re-export. Tradeoff documented in docs/architecture.md.
      "includes": ["src/server/domain/*/index.ts", "src/client/features/*/index.ts"],
      "linter": { "rules": { "performance": { "noBarrelFile": "off", "noReExportAll": "off" } } }
    },
    {
      // Server code logs through the observability module, never raw console.
      "includes": ["src/server/**"],
      "linter": {
        "rules": { "suspicious": { "noConsole": { "level": "error", "options": { "allow": [] } } } }
      }
    },
    {
      // The observability module is the one place pino itself is allowed.
      "includes": ["src/server/observability/**"],
      "linter": { "rules": { "style": { "noRestrictedImports": "off" } } }
    },
    {
      // scripts/ are CLI dev tools — console IS their output channel.
      "includes": ["scripts/**"],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    }
  ]
}
