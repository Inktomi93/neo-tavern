node_modules/
dist/
*.tsbuildinfo

# env
.env
.env.*
!.env.example

# data volume (libSQL db + assets) — mounted in prod, local in dev
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite

# ST corpus extraction staging (docker cp dumps the full private corpus here;
# never committed). The small curated fixtures under tests/fixtures/ ARE committed.
corpus-staging/

# Project-local CUDA-12 + cuDNN-9 runtime venv for GPU embedding (uv vendors NVIDIA's
# .so wheels here — multi-GB, machine-specific). pyproject.toml + uv.lock ARE committed
# (reproducible via `pnpm cuda:setup`); the materialized venv is not.
tools/cuda/.venv/
# api-map analysis tool's uv venv (reproducible via `pnpm api:map`; pyproject + uv.lock are committed).
tools/api-map/.venv/

# Model weights (BGE-M3, reranker) downloaded by transformers.js — repo-local + self-
# contained (MODEL_CACHE_DIR), re-downloadable, never committed.
.models/

# logs / os
*.log
.DS_Store

# claude code local settings
.claude/settings.local.json

# serena (MCP coding toolkit) project cache + config — machine-local tooling, not the project
.serena/

# local domain reference clones (SillyTavern, Astra, Marinara) — not part of this
# project; cloned for reference only. The README is tracked (documents how to
# repopulate); the clones themselves are not.
references/*
!references/README.md

# Local scratchpad/lab scripts
scratch/*
!scratch/.gitkeep

# TanStack Router temp
.tanstack/
\n# jscpd HTML reports\nreports/
