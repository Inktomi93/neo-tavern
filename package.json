{
  "name": "neo-tavern",
  "version": "0.1.0",
  "description": "Private single-user RP frontend + personal RAG/analytics layer over an RP corpus.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "LD_LIBRARY_PATH=\"$(find tools/cuda/.venv -type d -path '*/nvidia/*/lib' | tr '\\n' ':')$LD_LIBRARY_PATH\" tsx watch src/server/index.ts | pino-pretty",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server/index.ts",
    "check": "biome check . && tsc --noEmit && pnpm arch && vitest run --silent",
    "cpd": "jscpd",
    "cpd:report": "jscpd --reporters html --output reports/cpd",
    "db:generate:force": "yes | drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:baseline": "tsx scripts/db-baseline.ts",
    "db:reindex": "tsx scripts/db-reindex.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "arch": "depcruise src --config .dependency-cruiser.cjs",
    "arch:graph": "depcruise src --include-only ^src --output-type mermaid --config .dependency-cruiser.cjs --output-to docs/architecture/dependency-graph.mmd",
    "verify:claude": "tsx scripts/probes/verify-claude.ts",
    "verify:auth": "tsx scripts/verify-auth.ts",
    "sdk:play": "tsx scripts/probes/sdk-playground.ts",
    "import:st": "tsx scripts/import-st.ts",
    "assets:backfill": "tsx scripts/assets-backfill.ts",
    "assets:gc": "tsx scripts/assets-gc.ts",
    "assets:fsck": "tsx scripts/assets-fsck.ts",
    "embed:assets": "tsx scripts/embed-assets.ts",
    "embed:corpus": "tsx scripts/embed-corpus.ts",
    "memory:backfill": "tsx scripts/memory-backfill.ts",
    "backfill:content-hash": "tsx scripts/backfill-content-hash.ts",
    "find-duplicates": "tsx scripts/find-duplicates.ts",
    "compute-cooccurrence": "tsx scripts/compute-cooccurrence.ts",
    "embed:assets:gpu": "bash scripts/embed-assets-gpu.sh",
    "embed:corpus:gpu": "bash scripts/embed-corpus-gpu.sh",
    "csls": "tsx scripts/csls.ts",
    "cuda:setup": "uv sync --project tools/cuda",
    "api:map": "uv sync --project tools/api-map >/dev/null && uv run --project tools/api-map python tools/api-map/map_api.py",
    "api:q": "uv run --project tools/api-map python tools/api-map/q.py",
    "prepare": "husky",
    "probe:streaming": "tsx scripts/probes/probe-streaming.ts"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@anush008/tokenizers": "^0.6.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hono/node-server": "^2.0.3",
    "@hookform/resolvers": "^5.4.0",
    "@huggingface/transformers": "^4.2.0",
    "@libsql/client": "^0.17.3",
    "@openrouter/sdk": "^0.12.35",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-virtual": "^3.13.26",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@uiw/react-codemirror": "^4.25.10",
    "atomically": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.3",
    "hono": "^4.12.22",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.11",
    "node-llama-cpp": "^3.18.1",
    "openid-client": "^6.8.4",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^11.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^8.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "msw": "^2.14.6",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
