# Port the Hono server binds to. In dev, Vite (5173) proxies /api here.
# Default 8788 dodges the homelab's busy 3000/7xxx/8xxx/9xxx range.
PORT=8788

# Claude (sdk-mode / YGWYG): NO key needed here. It authenticates via the
# host's `claude login` (Max subscription). Verify with `pnpm verify:claude`.

# OpenRouter (raw-mode + non-Claude models). Required only for raw mode.
# OPENROUTER_API_KEY=sk-or-...

# Logging level: fatal|error|warn|info|debug|trace|silent (default info).
# LOG_LEVEL=info

# Enables the /api/_debug/* introspection API. UNSET = disabled (404). Set to any
# secret string; callers pass it via `x-debug-token` header or `?token=`.
# DEBUG_TOKEN=change-me-local-only

# ── Auth (defaults = single-user, zero infra; see docs/auth/auth-deploy.md) ──────────────────
# AUTH_MODE: single-user (default) | forward-header | oidc
# AUTH_FALLBACK: owner (default) | deny — identity for an UN-credentialed request.
#   In an SSO mode (oidc/forward-header) the `owner` fallback is ORIGIN-GATED: granted
#   ONLY on a local origin (raw LAN IP / localhost / a TRUSTED_LOCAL_HOSTS name), never
#   on the public FQDN (there SSO is mandatory). So oidc+owner = SSO on the domain AND
#   owner on the raw LAN IP, safely. single-user mode grants owner unconditionally.
# TRUSTED_LOCAL_HOSTS: extra hostnames (comma-list) counted as a local origin for that
#   fallback — for a raw-LAN path reached by name, e.g. a homelab hostname. NEVER list
#   the public FQDN here. Private/loopback IPs + `localhost` are local already.
# TRUSTED_LOCAL_HOSTS=neo.lan,homelab.local
