# Port the Hono server binds to. In dev, Vite (5173) proxies /api here.
# Default 8788 dodges the homelab's busy 3000/7xxx/8xxx/9xxx range.
PORT=8788

# Claude (sdk-mode / YGWYG): NO key needed here. It authenticates via the
# host's `claude login` (Max subscription). Verify with `pnpm verify:claude`.

# OpenRouter (raw-mode + non-Claude models). Required only for raw mode.
# OPENROUTER_API_KEY=sk-or-...

# Logging level: fatal|error|warn|info|debug|trace|silent (default info).
# LOG_LEVEL=info

# Enables the /api/_debug/* introspection API. UNSET = disabled (404). Set to any
# secret string; callers pass it via `x-debug-token` header or `?token=`.
# DEBUG_TOKEN=change-me-local-only
